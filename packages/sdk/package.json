{
  "name": "@beacon/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript SDK for Beacon - A comprehensive client library for real-time communication",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "beacon",
    "sdk",
    "websocket",
    "real-time",
    "chat",
    "communication",
    "api-client"
  ],
  "author": "Beacon Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raft-The-Crab/Beacon.git"
  },
  "bugs": {
    "url": "https://github.com/Raft-The-Crab/Beacon/issues"
  },
  "homepage": "https://github.com/Raft-The-Crab/Beacon#readme",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}