{
  "name": "beacon-sdk",
  "version": "3.5.0",
  "type": "commonjs",
  "description": "Official TypeScript SDK for the Beacon platform, bots, apps, gateway clients, and rich interactions",
  "main": "./dist/index.js",
  "browser": {
    "./dist/index.js": "./dist/browser.js",
    "wrtc": false,
    "opusscript": "./dist/stubs/opusscript.js",
    "stream": "./dist/stubs/stream.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "browser": "./dist/browser.js",
      "require": "./dist/browser.js",
      "default": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "publish:check": "npm pack --dry-run"
  },
  "keywords": [
    "beacon",
    "sdk",
    "bot",
    "gateway",
    "websocket",
    "real-time",
    "chat",
    "communication",
    "builders",
    "slash-commands"
  ],
  "author": "Beacon Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raft-The-Crab/Beacon.git"
  },
  "bugs": {
    "url": "https://github.com/Raft-The-Crab/Beacon/issues"
  },
  "homepage": "https://github.com/Raft-The-Crab/Beacon#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "eventemitter3": "^5.0.4",
    "isomorphic-ws": "^5.0.0",
    "opusscript": "^0.1.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  }
}
