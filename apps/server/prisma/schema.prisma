generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  username           String
  globalName         String?
  displayName        String?
  password           String
  avatar             String?
  banner             String?
  discriminator      String?
  bio                String?
  customStatus       String?
  status             String          @default("offline")
  twoFactorEnabled   Boolean         @default(false)
  twoFactorSecret    String?
  publicKey          String?
  deviceSalt         String?
  lastIp             String?
  locale             String?
  theme              String          @default("auto")
  accentColor        String?
  developerMode      Boolean         @default(false)
  badges             String[]        @default([])
  accountTier        AccountTier     @default(FREE)
  isBeaconPlus       Boolean         @default(false)
  beaconPlusSince    DateTime?
  beacoins           Int             @default(0)
  profileEffectId    String?
  avatarDecorationId String?
  bot                Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  passwordResetToken String?         @unique
  passwordResetExpires DateTime?
  isVerified         Boolean         @default(false)
  verificationCode   String?
  verificationExpires DateTime?
  loginAttempts      Int             @default(0)
  lockoutUntil       DateTime?
  applications       Application[]
  auditLogs          AuditLog[]
  blockedBy          Block[]         @relation("BlockedUsers")
  blocked            Block[]         @relation("UserBlocks")
  friendOf           Friendship[]    @relation("FriendUsers")
  friends            Friendship[]    @relation("UserFriends")
  ownedGuilds        Guild[]         @relation("GuildOwner")
  memberships        GuildMember[]
  messages           Message[]
  cosmetics          OwnedCosmetic[]
  folders            ServerFolder[]
  quests             UserQuest[]
  dmChannels         Channel[]       @relation("ChannelRecipients")
  sentGifts          Gift[]          @relation("SentGifts")
  receivedGifts      Gift[]          @relation("ReceivedGifts")
  createdInvites     Invite[]        @relation("InviteCreator")
  bans               GuildBan[]      @relation("BannedUser")

  @@unique([username, discriminator])
}

model ServerFolder {
  id        String   @id @default(cuid())
  name      String?
  color     String?
  userId    String
  guildIds  String[]
  position  Int      @default(0)
  expanded  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    Int
  createdAt DateTime @default(now())
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId, status])
  @@index([friendId, status])
}

model Block {
  id        String   @id @default(cuid())
  userId    String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedUsers", fields: [blockedId], references: [id], onDelete: Cascade)
  user      User     @relation("UserBlocks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedId])
}

model Guild {
  id          String           @id @default(cuid())
  name        String
  icon        String?
  banner      String?
  description String?
  verified    Boolean          @default(false)
  settings    Json             @default("{}")
  tags        String[]         @default([])
  ownerId     String
  inviteCode  String?          @unique @default(cuid())
  boostCount  Int              @default(0)
  boostLevel  Int              @default(0)
  vanityUrl   String?          @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  auditLogs   AuditLog[]
  channels    Channel[]
  emojis      CustomEmoji[]
  owner       User             @relation("GuildOwner", fields: [ownerId], references: [id])
  members     GuildMember[]
  invites     Invite[]
  bans        GuildBan[]
  roles       Role[]
  events      ScheduledEvent[]
  sounds      Sound[]
  stickers    Sticker[]
  webhooks    Webhook[]
}

model Role {
  id          String        @id @default(cuid())
  name        String
  color       String?
  position    Int           @default(0)
  permissions BigInt        @default(0)
  mentionable Boolean       @default(false)
  hoist       Boolean       @default(false)
  guildId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  guild       Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  members     GuildMember[] @relation("GuildMemberToRole")
}

model GuildMember {
  id       String   @id @default(cuid())
  userId   String
  guildId  String
  nickname String?
  avatar   String?
  joinedAt DateTime @default(now())
  guild    Guild    @relation(fields: [guildId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  roles    Role[]   @relation("GuildMemberToRole")

  @@unique([userId, guildId])
  @@index([userId])
  @@index([guildId])
}

model AuditLog {
  id         String   @id @default(cuid())
  guildId    String
  userId     String
  action     Int
  targetId   String?
  targetType String?
  changes    Json?
  reason     String?
  fingerprint Json?
  createdAt  DateTime @default(now())
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([guildId, createdAt])
  @@index([userId])
}

model Channel {
  id               String      @id @default(cuid())
  guildId          String?
  name             String
  type             ChannelType @default(TEXT)
  topic            String?
  position         Int         @default(0)
  parentId         String?
  nsfw             Boolean     @default(false)
  slowmode         Int         @default(0)
  rateLimitPerUser Int         @default(0)
  bitrate          Int?
  userLimit        Int?
  rtcRegion        String?
  videoQualityMode Int         @default(1)
  lastMessageAt    DateTime?   @default(now())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  guild            Guild?      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  parent           Channel?    @relation("SubChannels", fields: [parentId], references: [id])
  children         Channel[]   @relation("SubChannels")
  messages         Message[]
  threads          Thread[]
  webhooks         Webhook[]
  recipients       User[]      @relation("ChannelRecipients")
  invites          Invite[]

  @@index([guildId])
  @@index([parentId])
}

model Sound {
  id        String   @id @default(cuid())
  name      String
  url       String
  emoji     String?
  guildId   String
  creatorId String
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model ProfileEffect {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int      @default(0)
  rarity      String   @default("common")
  cssUrl      String
  createdAt   DateTime @default(now())
}

model AvatarDecoration {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int      @default(0)
  rarity      String   @default("common")
  url         String
  createdAt   DateTime @default(now())
}

model Thread {
  id                  String    @id @default(cuid())
  channelId           String
  name                String
  ownerId             String
  messageCount        Int       @default(0)
  memberCount         Int       @default(0)
  archived            Boolean   @default(false)
  locked              Boolean   @default(false)
  autoArchiveDuration Int       @default(1440)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  channel             Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages            Message[]
}

model Webhook {
  id        String    @id @default(cuid())
  channelId String
  guildId   String?
  name      String
  avatar    String?
  token     String    @unique
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  guild     Guild?    @relation(fields: [guildId], references: [id])
}

model Message {
  id          String       @id @default(cuid())
  content     String
  channelId   String
  authorId    String?
  webhookId   String?
  nonce       String?
  pinned      Boolean      @default(false)
  replyToId   String?
  threadId    String?
  embeds      Json         @default("[]")
  editedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  author      User?        @relation(fields: [authorId], references: [id])
  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  webhook     Webhook?     @relation(fields: [webhookId], references: [id])
  reactions   Reaction[]
  replyTo     Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[]    @relation("MessageReplies")
  thread      Thread?      @relation(fields: [threadId], references: [id])

  @@index([channelId, createdAt])
  @@index([authorId])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  isSuper   Boolean  @default(false)
  messageId String
  userId    String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  guildId   String
  channelId String?
  inviterId String?
  uses      Int       @default(0)
  maxUses   Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channel   Channel?  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  inviter   User?     @relation("InviteCreator", fields: [inviterId], references: [id])
}

model GuildBan {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  reason      String?
  moderatorId String?
  createdAt   DateTime @default(now())
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user        User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
}

model Application {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
  bot         Bot?
}

model Bot {
  id            String         @id @default(cuid())
  token         String         @unique
  applicationId String         @unique
  userId        String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  application   Application    @relation(fields: [applicationId], references: [id])
  commands      SlashCommand[]
}

model SlashCommand {
  id          String   @id @default(cuid())
  name        String
  description String
  botId       String
  guildId     String?
  options     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model VoiceState {
  id        String   @id @default(cuid())
  userId    String
  guildId   String
  channelId String?
  sessionId String   @unique
  deaf      Boolean  @default(false)
  mute      Boolean  @default(false)
  selfDeaf  Boolean  @default(false)
  selfMute  Boolean  @default(false)
  selfVideo Boolean  @default(false)
  suppress  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId])
  @@index([userId])
  @@index([channelId])
}

model Attachment {
  id          String   @id @default(cuid())
  messageId   String
  filename    String
  size        Int
  url         String
  proxyUrl    String?
  height      Int?
  width       Int?
  contentType String?
  createdAt   DateTime @default(now())
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  read      Boolean          @default(false)
  metadata  Json?
  iconUrl   String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model UserPresence {
  id           String         @id @default(cuid())
  userId       String         @unique
  status       PresenceStatus @default(OFFLINE)
  customStatus String?
  activities   Json?
  lastSeen     DateTime       @default(now())
  platform     String?
  updatedAt    DateTime       @updatedAt

  @@index([status])
}

model CustomEmoji {
  id        String   @id @default(cuid())
  name      String
  guildId   String
  imageUrl  String
  animated  Boolean  @default(false)
  creatorId String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, name])
}

model Sticker {
  id          String        @id @default(cuid())
  name        String
  description String?
  guildId     String
  imageUrl    String
  formatType  StickerFormat @default(PNG)
  tags        String?
  creatorId   String
  createdAt   DateTime      @default(now())
  guild       Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model ScheduledEvent {
  id              String          @id @default(cuid())
  guildId         String
  name            String
  description     String?
  channelId       String?
  location        String?
  imageUrl        String?
  startTime       DateTime
  endTime         DateTime?
  status          EventStatus     @default(SCHEDULED)
  creatorId       String
  entityType      EventEntityType @default(VOICE)
  interestedCount Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  guild           Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, startTime])
}

model UserNote {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, targetId])
}

model BeacoinWallet {
  id           String               @id @default(cuid())
  userId       String               @unique
  balance      Int                  @default(0)
  lifetime     Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  transactions BeacoinTransaction[]
}

model BeacoinTransaction {
  id         String        @id @default(cuid())
  walletId   String
  type       BeacoinTxType
  amount     Int
  reason     String
  meta       Json?
  fromUserId String?
  toUserId   String?
  createdAt  DateTime      @default(now())
  wallet     BeacoinWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([fromUserId])
  @@index([toUserId])
}

model UserPremium {
  id            String      @id @default(cuid())
  userId        String      @unique
  tier          PremiumTier @default(NONE)
  expiresAt     DateTime?
  autoRenew     Boolean     @default(true)
  purchasedWith Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PremiumPerk {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  tier        PremiumTier
  value       Json?
  createdAt   DateTime    @default(now())
}

model OwnedCosmetic {
  id          String   @id @default(cuid())
  userId      String
  cosmeticId  String
  type        String
  purchasedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
}

model Quest {
  id          String      @id @default(uuid())
  title       String
  description String
  reward      Int         @default(0)
  total       Int
  type        String
  duration    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userQuests  UserQuest[]
}

model UserQuest {
  id        String   @id @default(uuid())
  userId    String
  questId   String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
}

enum ChannelType {
  TEXT
  VOICE
  CATEGORY
  THREAD
  STAGE
  FORUM
  ANNOUNCEMENT
  DM
  GROUP_DM
  DIRECTORY
  STORE
  MEDIA
  TICKET
  RULES
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum NotificationType {
  MESSAGE_MENTION
  FRIEND_REQUEST
  GUILD_INVITE
  MODERATION_ACTION
  SYSTEM_ALERT
  BOT_RESPONSE
  SCHEDULED_EVENT
  BOOST
}

enum AccountTier {
  FREE
  BEACON_PLUS
  ADMIN
}

enum PresenceStatus {
  ONLINE
  IDLE
  DND
  INVISIBLE
  OFFLINE
}

enum StickerFormat {
  PNG
  APNG
  LOTTIE
  GIF
}

enum EventStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EventEntityType {
  STAGE
  VOICE
  EXTERNAL
}

enum BeacoinTxType {
  EARN
  SPEND
  ADJUST
  TRANSFER
}

enum PremiumTier {
  NONE
  PREMIUM
}

model Gift {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  cosmeticId  String?
  type        String // SUBSCRIPTION, COSMETIC
  message     String?
  claimed     Boolean  @default(false)
  createdAt   DateTime @default(now())
  sender      User     @relation("SentGifts", fields: [senderId], references: [id])
  recipient   User     @relation("ReceivedGifts", fields: [recipientId], references: [id])

  @@index([senderId])
  @@index([recipientId])
}
