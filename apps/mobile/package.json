{
  "name": "@beacon/mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cap sync && cap open android",
    "build": "cap sync && cap copy android",
    "build:apk": "npm run build && cd android && gradlew.bat assembleRelease",
    "build:bundle": "npm run build && cd android && gradlew.bat bundleRelease",
    "build:debug": "npm run build && cd android && gradlew.bat assembleDebug",
    "sync": "cap sync android",
    "open": "cap open android",
    "clean": "cd android && gradlew.bat clean",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "@beacon/types": "file:../../packages/types",
    "@beacon/api-client": "file:../../packages/api-client",
    "@capacitor/core": "^7.0.0",
    "@capacitor/android": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.3.0"
  }
}