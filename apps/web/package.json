{
  "name": "@beacon/web",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:deps && tsc && vite build",
    "build:deps": "pnpm --filter beacon-sdk build && pnpm --filter beacon-types build",
    "preview": "vite preview",
    "build:mobile": "npm run build && cd ../mobile && npm run sync",
    "build:android": "npm run build && cd ../mobile && npm run sync && npm run open",
    "build:android:release": "npm run build && cd ../mobile && npm run build:apk",
    "build:android:aab": "npm run build && cd ../mobile && npm run build:bundle",
    "build:desktop": "npm run build && cd ../desktop && npm run build",
    "build:desktop:release": "npm run build && cd ../desktop && npm run build:release",
    "desktop:dev": "cd ../desktop && npm run dev",
    "android:open": "cd ../mobile && npm run open",
    "android:sync": "cd ../mobile && npm run sync"
  },
  "dependencies": {
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capawesome/capacitor-badge": "^6.0.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@types/simple-peer": "^9.11.9",
    "axios": "^1.13.5",
    "beacon-sdk": "file:../../packages/sdk",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.34.3",
    "howler": "^2.2.4",
    "lucide-react": "^0.468.0",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "react-virtuoso": "^4.18.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "simple-peer": "^9.11.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^1.6.0",
    "@types/howler": "^2.2.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  }
}
